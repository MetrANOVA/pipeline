PIPELINE_YAML=/app/pipelines/metadata_iri.yml
CLICKHOUSE_CACHER_TABLES=meta_iri_resource,meta_iri_event,meta_iri_incident,meta_iri_facility,meta_iri_site
CLICKHOUSE_CACHER_REFRESH_INTERVAL=0 # these are refreshed everytime HTTP consumer runs, so don't need periodic
HTTP_CONSUMER_UPDATE_INTERVAL=300
HTTP_CONSUMER_SLEEP_PER_URL_TIME=5 # sleep time between each url fetch to give clickhouse time to update
##
# Below are IRI URLs to fetch. In order to ensure ref lookups put facility, sites, resources, incidents and 
# events urls in that order
# NOTE: The IRI_* variables are not recognized by pipeline and only used for organization purpose to build 
# HTTP_CONSUMER_URLS which is recognized by pipeline. This is to allow for better organization and readability 
# of urls since there are so many.
IRI_FACILITY_URLS="https://api.alcf.anl.gov/api/v1/facility,https://api.iri.nersc.gov/api/v1/facility"
IRI_SITE_URLS="https://api.alcf.anl.gov/api/v1/facility/sites,https://api.iri.nersc.gov/api/v1/facility/sites"
IRI_RESOURCE_URLS="https://api.alcf.anl.gov/api/v1/status/resources,https://api.iri.nersc.gov/api/v1/status/resources"
IRI_INCIDENT_URLS="https://api.iri.nersc.gov/api/v1/status/incidents?limit=1000" #TODO: if no limit then only returns 100. Need better strategy like poll by time or paginate
IRI_EVENT_URLS="https://api.iri.nersc.gov/api/v1/status/events?limit=1000" #TODO: ditto for limit
HTTP_CONSUMER_URLS="${IRI_FACILITY_URLS},${IRI_SITE_URLS},${IRI_RESOURCE_URLS},${IRI_INCIDENT_URLS},${IRI_EVENT_URLS}"
# URLs below are for older API version where need to walkthrough incidents to get events. Can remove once all data sources are updated to new API spec that has separate events endpoint.
IRI_INCIDENT_EVENT_CONSUMER_UPDATE_INTERVAL=300
IRI_INCIDENT_EVENT_CONSUMER_URLS="https://api.alcf.anl.gov/api/v1/status/incidents"