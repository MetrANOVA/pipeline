# Pipeline Configuration
PIPELINE_YAML=pipelines/metadata_esdb_device.yml

# GraphQL Consumer Settings
GRAPHQL_CONSUMER_ENV_PREFIX=DEVICE
DEVICE_GRAPHQL_ENDPOINT=ADDURL
DEVICE_GRAPHQL_TOKEN=CHANGEME
DEVICE_GRAPHQL_CONSUMER_UPDATE_INTERVAL=36000
DEVICE_URL_MATCH_PATTERN=esdb

# GraphQL ESDB Service Edge Query
DEVICE_GRAPHQL_QUERY=query { equipmentList { list { id name equipmentState { name } hostname network { name } role { name } os { name } model { name manufacturer { shortName } } location { shortName fullName latitude longitude locationType { name } } } } }